# Based Agent — environment configuration
# Copy this to .env and fill in your key(s).
# Anthropic is checked first; OpenAI is used as fallback.
# You only need one.

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Optional overrides — sensible defaults are used if not set
# ─────────────────────────────────────────────────────────────────

# Override the model used by createModelAdapter()
# Anthropic default: claude-opus-4-5  |  OpenAI default: gpt-4o
# BASED_AGENT_DEFAULT_MODEL=claude-opus-4-5

# Maximum loop iterations before the agent forcibly stops (default: 100)
# BASED_AGENT_MAX_ITERATIONS=100

# Maximum tokens per model response (default: 8192)
# BASED_AGENT_MAX_TOKENS=8192

# ─────────────────────────────────────────────────────────────────
# Enterprise / production options
# (Set in code via AgentConfig — listed here for documentation)
# ─────────────────────────────────────────────────────────────────

# tokenBudget     — hard cumulative token ceiling per run
#                   Loop stops with done: budget_exceeded when exceeded.
#                   Example in code: createAgent({ ...config, tokenBudget: 50_000 })

# approvalHandler — handler for ask-tier permission decisions
#                   CliApprovalHandler: interactive y/N in terminal
#                   AutoApproveHandler: always allow (CI/trusted contexts)
#                   Example: createAgent({ ...config, approvalHandler: new CliApprovalHandler() })

# logger          — EventLogger called on every AgentEvent before yield
#                   ConsoleLogger: structured JSON to stderr
#                   NdJsonLogger:  NDJSON to any writable stream
#                   Example: createAgent({ ...config, logger: new ConsoleLogger() })
